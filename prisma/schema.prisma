generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  username   String    @unique
  password   String
  birthDate  DateTime
  agreedToTerms Boolean @default(false)
  role       Role      @default(USER)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  posts      Post[]
  soundToks  SoundTok[]
  comments   Comment[]
  sentMessages Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  chatUsers   ChatUser[]
  createdBattles Battle[] @relation("CreatedBattles")
  battleParticipants BattleParticipant[]
  battleRecordings BattleRecording[]

  @@map("users")
}

model Post {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  media     Media[]

  @@map("posts")
}

model Media {
  id        String   @id @default(cuid())
  type      MediaType
  url       String
  postId    String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("media")
}

model SoundTok {
  id          String   @id @default(cuid())
  description String
  videoUrl    String
  authorId    String
  likes       Int      @default(0)
  commentsCount Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    Comment[]

  @@map("sound_toks")
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  authorId  String
  soundTokId String
  createdAt DateTime @default(now())

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  soundTok  SoundTok @relation(fields: [soundTokId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Chat {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  Message[]
  users     ChatUser[]

  @@map("chats")
}

model Message {
  id        String   @id @default(cuid())
  content   String
  senderId  String
  receiverId String
  chatId    String
  createdAt DateTime @default(now())

  sender    User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver  User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model ChatUser {
  id     String @id @default(cuid())
  userId String
  chatId String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([userId, chatId])
  @@map("chat_users")
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
}

enum BattleStatus {
  WAITING
  INVITING
  SELECTING_BEAT
  USER1_TURN
  USER2_TURN
  JUDGING
  FINISHED
  CANCELLED
}

enum BattleParticipantRole {
  CREATOR
  OPPONENT
  JUDGE
}

enum BattleWinner {
  USER1
  USER2
  DRAW
}

model Battle {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      BattleStatus @default(WAITING)
  creatorId   String
  beatUrl     String?
  beatName    String?
  winner      BattleWinner?
  judgedBy    String?      // ID of AI judge or user judge
  judgedAt    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  creator     User                 @relation("CreatedBattles", fields: [creatorId], references: [id], onDelete: Cascade)
  participants BattleParticipant[]
  recordings  BattleRecording[]

  @@map("battles")
}

model BattleParticipant {
  id         String               @id @default(cuid())
  battleId   String
  userId     String
  role       BattleParticipantRole
  acceptedAt DateTime?
  createdAt  DateTime             @default(now())

  battle     Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([battleId, userId, role])
  @@map("battle_participants")
}

model BattleRecording {
  id          String   @id @default(cuid())
  battleId    String
  userId      String
  voiceUrl    String
  voiceBlob   Bytes?   // Store audio blob directly in DB
  beatUrl     String
  duration    Float    // in seconds
  recordingQuality String @default("medium") // low, medium, high
  createdAt   DateTime @default(now())

  battle      Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("battle_recordings")
}

model BattleJudge {
  id              String   @id @default(cuid())
  battleId        String   @unique
  judgeType       String   @default("ai") // ai, user
  user1Flow       Float    @default(0)
  user1Lyrics     Float    @default(0)
  user1Delivery   Float    @default(0)
  user2Flow       Float    @default(0)
  user2Lyrics     Float    @default(0)
  user2Delivery   Float    @default(0)
  user1Total      Float    @default(0)
  user2Total      Float    @default(0)
  feedback        String?  // AI feedback text
  confidence      Float?   // AI confidence score
  createdAt       DateTime @default(now())

  @@map("battle_judges")
}
