generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum ChatType {
  DIRECT
  GROUP
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  username   String    @unique
  password   String
  birthDate  DateTime
  agreedToTerms Boolean @default(false)
  role       Role      @default(USER)
  
  // Profile fields
  displayName String?
  avatar      String?
  bio         String?   @db.Text
  
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  posts      Post[]
  soundToks  SoundTok[]
  comments   Comment[]
  likes      Like[]
  sentMessages Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  chatUsers   ChatUser[]
  createdBattles Battle[] @relation("CreatedBattles")
  battleParticipants BattleParticipant[]
  battleRecordings BattleRecording[]
  battleRatings BattleRating[]

  followers Follow[] @relation("UserFollowers")
  following Follow[] @relation("UserFollowing")
  blocks    Block[] @relation("UserBlocks")
  blockedBy Block[] @relation("UserBlockedBy")

  @@map("users")
}

model Post {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  media     Media[]

  @@map("posts")
}

model Media {
  id        String   @id @default(cuid())
  type      MediaType
  url       String
  postId    String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("media")
}

model SoundTok {
  id          String   @id @default(cuid())
  description String
  videoUrl    String
  authorId    String
  likes       Int      @default(0)
  commentsCount Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    Comment[]
  likesList   Like[]
  sharedMessages Message[]

  @@map("sound_toks")
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  authorId  String
  soundTokId String
  createdAt DateTime @default(now())

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  soundTok  SoundTok @relation(fields: [soundTokId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  soundTokId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  soundTok  SoundTok @relation(fields: [soundTokId], references: [id], onDelete: Cascade)

  @@unique([userId, soundTokId])
  @@map("likes")
}

model Chat {
  id        String   @id @default(cuid())
  type      ChatType @default(DIRECT)
  name      String?
  creatorId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  Message[]
  users     ChatUser[]

  @@map("chats")
}

model Message {
  id        String   @id @default(cuid())
  content   String
  senderId  String
  receiverId String?
  chatId    String
  soundTokId String?
  
  // For deduplication and status tracking
  clientMessageId String?   // ID generated on client to prevent duplicates
  status      MessageStatus @default(SENT)
  readAt      DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender    User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver  User?    @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  soundTok  SoundTok? @relation(fields: [soundTokId], references: [id], onDelete: SetNull)

  @@unique([clientMessageId, chatId]) // Prevent duplicate messages from same client
  @@index([chatId, createdAt])         // Optimize message history queries
  @@index([senderId, status])          // Optimize status update queries
  @@index([soundTokId])
  @@map("messages")
}

model ChatUser {
  id         String    @id @default(cuid())
  userId     String
  chatId     String
  pinnedAt   DateTime?
  lastReadAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([userId, chatId])
  @@map("chat_users")
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
}

enum BattleStatus {
  WAITING
  INVITING
  SELECTING_BEAT
  USER1_TURN
  USER2_TURN
  JUDGING
  FINISHED
  CANCELLED
}

enum BattleParticipantRole {
  CREATOR
  OPPONENT
  JUDGE
}

enum BattleWinner {
  USER1
  USER2
  DRAW
}

model Battle {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      BattleStatus @default(WAITING)
  creatorId   String
  beatUrl     String?
  beatName    String?
  winner      BattleWinner?
  judgedBy    String?      // ID of AI judge or user judge
  judgedAt    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  creator     User                 @relation("CreatedBattles", fields: [creatorId], references: [id], onDelete: Cascade)
  participants BattleParticipant[]
  recordings  BattleRecording[]
  ratings     BattleRating[]

  @@map("battles")
}

model BattleParticipant {
  id         String               @id @default(cuid())
  battleId   String
  userId     String
  role       BattleParticipantRole
  acceptedAt DateTime?
  createdAt  DateTime             @default(now())

  battle     Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([battleId, userId, role])
  @@map("battle_participants")
}

model BattleRecording {
  id          String   @id @default(cuid())
  battleId    String
  userId      String
  voiceUrl    String
  voiceBlob   Bytes?   // Store audio blob directly in DB
  beatUrl     String
  duration    Float    // in seconds
  recordingQuality String @default("medium") // low, medium, high
  createdAt   DateTime @default(now())

  battle      Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("battle_recordings")
}

model BattleRating {
  id        String   @id @default(cuid())
  battleId  String
  raterId   String
  rating    Int
  createdAt DateTime @default(now())

  battle    Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  rater     User   @relation(fields: [raterId], references: [id], onDelete: Cascade)

  @@unique([battleId, raterId])
  @@map("battle_ratings")
}

model BattleJudge {
  id              String   @id @default(cuid())
  battleId        String   @unique
  judgeType       String   @default("ai") // ai, user
  user1Flow       Float    @default(0)
  user1Lyrics     Float    @default(0)
  user1Delivery   Float    @default(0)
  user2Flow       Float    @default(0)
  user2Lyrics     Float    @default(0)
  user2Delivery   Float    @default(0)
  user1Total      Float    @default(0)
  user2Total      Float    @default(0)
  feedback        String?  // AI feedback text
  confidence      Float?   // AI confidence score
  createdAt       DateTime @default(now())

  @@map("battle_judges")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("UserBlocks", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}
