generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum PlanTier {
  FREE
  PRO
  PLATINUM
}

enum PaymentKind {
  PLAN_PRO
  PLAN_PLATINUM
  TOKENS_400
}

enum PaymentStatus {
  PENDING
  WAITING_FOR_CAPTURE
  SUCCEEDED
  CANCELED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  MESSAGE
}

enum ChatType {
  DIRECT
  GROUP
}

enum PresetStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PresetPurchaseStatus {
  PAID
  REFUNDED
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  username   String    @unique
  password   String?   // null for OAuth-only accounts
  birthDate  DateTime
  agreedToTerms Boolean @default(false)
  role       Role      @default(USER)

  // Email verification
  emailVerified            Boolean   @default(false)
  emailVerificationCode    String?
  emailVerificationExpires DateTime?

  // OAuth providers
  googleId String? @unique
  vkId     String? @unique
  
  // Profile fields
  displayName String?
  avatar      String?
  bio         String?   @db.Text

  // Subscription / tokens
  plan              PlanTier  @default(FREE)
  planExpiresAt     DateTime?
  tokenBalance      Int       @default(0)
  /// YYYY-MM-DD (UTC) bucket for Platinum daily cloud-save cap
  midiSavesDayKey   String?
  midiSavesToday    Int       @default(0)
  
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  posts      Post[]
  soundToks  SoundTok[]
  comments   Comment[]
  likes      Like[]
  sentMessages Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  chatUsers   ChatUser[]
  createdBattles Battle[] @relation("CreatedBattles")
  battleParticipants BattleParticipant[]
  battleRecordings BattleRecording[]
  battleRatings BattleRating[]
  midiProjects MidiProject[]
  midiSamples MidiSample[]
  presets     Preset[]         @relation("PresetSeller")
  presetPurchases PresetPurchase[] @relation("PresetBuyer")
  postLikes   PostLike[]
  postComments PostComment[]
  postViews   PostView[]
  notifications Notification[] @relation("NotificationRecipient")
  sentNotifications Notification[] @relation("NotificationActor")
  payments   Payment[]

  followers Follow[] @relation("UserFollowers")
  following Follow[] @relation("UserFollowing")
  blocks    Block[] @relation("UserBlocks")
  blockedBy Block[] @relation("UserBlockedBy")

  @@map("users")
}

model Preset {
  id              String       @id @default(cuid())
  sellerId        String
  title           String
  description     String       @db.Text
  priceCents      Int          @default(0)
  currency        String       @default("RUB")
  tags            String[]     @default([])
  status          PresetStatus @default(DRAFT)
  packageKey      String?
  packageName     String?
  packageSize     Int?
  previewUrl      String?
  coverUrl        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  seller          User             @relation("PresetSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  purchases       PresetPurchase[]

  @@index([status, createdAt])
  @@index([sellerId, updatedAt])
  @@map("presets")
}

model PresetPurchase {
  id          String               @id @default(cuid())
  buyerId     String
  presetId    String
  amountCents Int
  currency    String
  status      PresetPurchaseStatus @default(PAID)
  provider    String               @default("demo")
  providerRef String?
  purchasedAt DateTime             @default(now())

  buyer       User   @relation("PresetBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  preset      Preset @relation(fields: [presetId], references: [id], onDelete: Cascade)

  @@unique([buyerId, presetId])
  @@index([presetId, status])
  @@map("preset_purchases")
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  kind              PaymentKind
  status            PaymentStatus @default(PENDING)
  amountRub         Int
  yookassaPaymentId String?       @unique
  confirmationUrl   String?
  description       String
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("payments")
}

model MidiProject {
  id        String   @id @default(cuid())
  name      String
  data      Json
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  samples MidiSample[]

  @@index([ownerId, updatedAt])
  @@map("midi_projects")
}

model MidiSample {
  id        String   @id @default(cuid())
  name      String
  mimeType  String
  data      Bytes
  size      Int
  ownerId   String
  projectId String
  createdAt DateTime @default(now())

  owner   User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  project MidiProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([projectId])
  @@map("midi_samples")
}

model Post {
  id            String        @id @default(cuid())
  content       String
  authorId      String
  likes         Int           @default(0)
  commentsCount Int           @default(0)
  views         Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  author        User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  media         Media[]
  likesList     PostLike[]
  comments      PostComment[]
  viewers       PostView[]

  @@map("posts")
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@map("post_likes")
}

model PostComment {
  id        String   @id @default(cuid())
  text      String   @db.Text
  authorId  String
  postId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("post_comments")
}

model PostView {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@map("post_views")
}

model Media {
  id        String   @id @default(cuid())
  type      MediaType
  url       String
  postId    String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("media")
}

model SoundTok {
  id          String   @id @default(cuid())
  description String
  videoUrl    String
  authorId    String
  likes       Int      @default(0)
  commentsCount Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    Comment[]
  likesList   Like[]
  sharedMessages Message[]

  @@map("sound_toks")
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  authorId  String
  soundTokId String
  createdAt DateTime @default(now())

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  soundTok  SoundTok @relation(fields: [soundTokId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  soundTokId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  soundTok  SoundTok @relation(fields: [soundTokId], references: [id], onDelete: Cascade)

  @@unique([userId, soundTokId])
  @@map("likes")
}

model Chat {
  id        String   @id @default(cuid())
  type      ChatType @default(DIRECT)
  name      String?
  creatorId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  Message[]
  users     ChatUser[]

  @@map("chats")
}

model Message {
  id        String   @id @default(cuid())
  content   String
  senderId  String
  receiverId String?
  chatId    String
  soundTokId String?
  
  // For deduplication and status tracking
  clientMessageId String?   // ID generated on client to prevent duplicates
  status      MessageStatus @default(SENT)
  readAt      DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender    User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver  User?    @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  soundTok  SoundTok? @relation(fields: [soundTokId], references: [id], onDelete: SetNull)

  @@unique([clientMessageId, chatId]) // Prevent duplicate messages from same client
  @@index([chatId, createdAt])         // Optimize message history queries
  @@index([senderId, status])          // Optimize status update queries
  @@index([soundTokId])
  @@map("messages")
}

model ChatUser {
  id         String    @id @default(cuid())
  userId     String
  chatId     String
  pinnedAt   DateTime?
  lastReadAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([userId, chatId])
  @@map("chat_users")
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
}

enum BattleStatus {
  WAITING
  INVITING
  SELECTING_BEAT
  USER1_TURN
  USER2_TURN
  JUDGING
  FINISHED
  CANCELLED
}

enum BattleParticipantRole {
  CREATOR
  OPPONENT
  JUDGE
}

enum BattleWinner {
  USER1
  USER2
  DRAW
}

model Battle {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      BattleStatus @default(WAITING)
  creatorId   String
  beatUrl     String?
  beatName    String?
  winner      BattleWinner?
  judgedBy    String?      // ID of AI judge or user judge
  judgedAt    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  creator     User                 @relation("CreatedBattles", fields: [creatorId], references: [id], onDelete: Cascade)
  participants BattleParticipant[]
  recordings  BattleRecording[]
  ratings     BattleRating[]

  @@map("battles")
}

model BattleParticipant {
  id         String               @id @default(cuid())
  battleId   String
  userId     String
  role       BattleParticipantRole
  acceptedAt DateTime?
  createdAt  DateTime             @default(now())

  battle     Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([battleId, userId, role])
  @@map("battle_participants")
}

model BattleRecording {
  id          String   @id @default(cuid())
  battleId    String
  userId      String
  voiceUrl    String
  voiceBlob   Bytes?   // Store audio blob directly in DB
  beatUrl     String
  duration    Float    // in seconds
  recordingQuality String @default("medium") // low, medium, high
  createdAt   DateTime @default(now())

  battle      Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("battle_recordings")
}

model BattleRating {
  id        String   @id @default(cuid())
  battleId  String
  raterId   String
  rating    Int
  createdAt DateTime @default(now())

  battle    Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  rater     User   @relation(fields: [raterId], references: [id], onDelete: Cascade)

  @@unique([battleId, raterId])
  @@map("battle_ratings")
}

model BattleJudge {
  id              String   @id @default(cuid())
  battleId        String   @unique
  judgeType       String   @default("ai") // ai, user
  user1Flow       Float    @default(0)
  user1Lyrics     Float    @default(0)
  user1Delivery   Float    @default(0)
  user2Flow       Float    @default(0)
  user2Lyrics     Float    @default(0)
  user2Delivery   Float    @default(0)
  user1Total      Float    @default(0)
  user2Total      Float    @default(0)
  feedback        String?  // AI feedback text
  confidence      Float?   // AI confidence score
  createdAt       DateTime @default(now())

  @@map("battle_judges")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  actorId    String
  type       NotificationType
  entityType String?
  entityId   String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  user  User @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("UserBlocks", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}
