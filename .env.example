# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/hacaton_db"

# JWT — REQUIRED in production (min 32 random chars). Never use "secret".
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# Server
NODE_ENV="development"
PORT=5002
# Production must bind to loopback (nginx proxies): HOST=127.0.0.1
HOST="0.0.0.0"
FRONTEND_URL="http://localhost:5173"
BACKEND_URL="http://localhost:5002"
CORS_ORIGIN="http://localhost:5173"

# Postgres (production docker) — never expose 5432 to the internet
POSTGRES_PASSWORD="change-me-strong-password"

# Logging
LOG_LEVEL="info"

# Suno API
SUNO_API_KEY="sk-demo-key-replace-with-real-one"

# Email (SMTP) — required for real verification codes
# Example: Yandex / Gmail / Mailgun
SMTP_HOST="smtp.yandex.ru"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="noreply@yourdomain.ru"
SMTP_PASS="app-password"
SMTP_FROM="SoundLab <noreply@yourdomain.ru>"

# Resend (preferred) — https://resend.com
# After domain DNS is verified:
RESEND_API_KEY=""
EMAIL_FROM="SoundLab <noreply@soundlab-studio.ru>"

# Google OAuth — https://console.cloud.google.com/
# Authorized redirect URI: {BACKEND_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# VK OAuth — https://dev.vk.com/
# Redirect URI: {BACKEND_URL}/api/auth/vk/callback
VK_CLIENT_ID=""
VK_CLIENT_SECRET=""

# YooKassa (test or live)
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""
# Optional — only for native mobile SDK
YOOKASSA_MOBILE_SDK_KEY=""
